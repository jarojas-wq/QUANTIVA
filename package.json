{
  "name": "itemicostos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "worker:bim": "node workers/bim-cloud-worker.mjs",
    "worker:bim:once": "node workers/bim-cloud-worker.mjs --once",
    "worker:bim:check": "node workers/bim-cloud-worker.mjs --check-provider",
    "worker:bim:check-live": "node workers/bim-cloud-worker.mjs --check-provider-live",
    "worker:bim:list-activities": "node workers/aps-activities.mjs",
    "worker:bim:load-test": "node workers/bim-cloud-load-test.mjs",
    "bim:setup-local": "node workers/bim-local-env.mjs",
    "bim:prepare-smoke": "node workers/bim-smoke-config.mjs",
    "bim:readiness": "node workers/bim-readiness.mjs",
    "bim:revit-session": "node workers/bim-revit-local-session.mjs",
    "bim:fluency-check": "node workers/bim-fluency-check.mjs",
    "bim:realtime-load-test": "node workers/bim-realtime-load-test.mjs",
    "revit:bim-batch-plan": "dotnet run --project ../REVIT-MODEL-AUDITOR/src/RevitModelAudit.Benchmarks -- --bim-batch-plan",
    "revit:bim-bridge-backoff": "dotnet run --project ../REVIT-MODEL-AUDITOR/src/RevitModelAudit.Benchmarks -- --bim-bridge-backoff --json",
    "revit:bim-cancellation-probe": "dotnet run --project ../REVIT-MODEL-AUDITOR/src/RevitModelAudit.Benchmarks -- --bim-cancellation-probe --json",
    "revit:bim-transaction-failure": "dotnet run --project ../REVIT-MODEL-AUDITOR/src/RevitModelAudit.Benchmarks -- --bim-transaction-failure --json",
    "bim:api-smoke": "node workers/bim-api-smoke.mjs",
    "bim:bridge-smoke": "node workers/bim-bridge-smoke.mjs",
    "bim:bridge-e2e-smoke": "node workers/bim-bridge-e2e-smoke.mjs",
    "bim:active-revit-e2e": "node workers/bim-active-revit-e2e.mjs",
    "server": "node server.js",
    "start": "node server.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "mysql2": "^3.15.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
