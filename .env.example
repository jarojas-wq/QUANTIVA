ITEMICOSTOS_STORAGE=google-apps-script
GOOGLE_APPS_SCRIPT_WEBAPP_URL=
GOOGLE_APPS_SCRIPT_TOKEN=
GOOGLE_APPS_SCRIPT_TIMEOUT_MS=20000

# Si prefieres Google Sheets API (requiere Google Cloud), usa:
# ITEMICOSTOS_STORAGE=google-sheets
# GOOGLE_SHEETS_SPREADSHEET_ID=
# GOOGLE_SHEETS_CREATE_IF_MISSING=false
# GOOGLE_SHEETS_TITLE=Itemicostos

# Para MySQL / Cloud SQL usa:
# ITEMICOSTOS_STORAGE=mysql
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=MTRD
# REVIT_INGEST_API_KEY=
# MYSQL_SOCKET_PATH=
# MYSQL_SSL_CA_PATH=
# SQLITE_PATH=data/itemicostos.sqlite

# Opcion 1: usar credenciales por archivo
# GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\a\service-account.credentials.json

# Opcion 2: usar JSON inline
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
